# Hue Monitor environment variables
# Copy this file to .env and fill in values as needed.

# Optional: Dead-man heartbeat URL (Healthchecks.io ping URL)
# Used by src/heartbeat.py. Leave blank to disable heartbeat pings.
HEALTHCHECKS_URL=

# Optional future overrides (currently configured via ~/.hue-monitor/config.json)
HUE_BRIDGE_IP=
HUE_BRIDGE_KEY=
HUE_SENSOR_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
